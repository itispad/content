# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for Phase 2: storing OAuth tokens and dashboard data server-side.
SUPABASE_SERVICE_ROLE_KEY=

# App URL (for OAuth redirects). Use https in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google / YouTube OAuth (Phase 2). Create at https://console.cloud.google.com/
# Enable YouTube Data API v3 (and optionally YouTube Analytics API).
# Create OAuth 2.0 Client ID (Web application):
#   Authorized JavaScript origins:  http://localhost:3000  (and https://your-domain.com in prod)
#   Authorized redirect URIs:      http://localhost:3000/api/oauth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
